{
  "name": "Valheim",
  "slug": "valheim",
  "author": "ops@refx.example",
  "description": "Iron Gate's Norse survival sandbox dedicated server. SteamCMD-installed with optional BepInEx mod loader support.",
  "category": "survival",
  "deployMethods": [
    "DOCKER",
    "NATIVE_PROCESS"
  ],
  "supportsLinux": true,
  "supportsWindows": false,
  "dockerImages": {
    "Default": "ghcr.io/parkervcp/steamcmd:debian"
  },
  "steamAppId": 896660,
  "startupCommand": "env LD_LIBRARY_PATH=./linux64 SteamAppId=892970 ./valheim_server.x86_64 -nographics -batchmode -name \"{{SERVER_NAME}}\" -port {{SERVER_PORT}} -world \"{{WORLD_NAME}}\" -password \"{{SERVER_PASS}}\" -public {{PUBLIC}} -crossplay",
  "startupDetect": "Game server connected|DungeonDB Start",
  "stopCommand": "^C",
  "installScript": {
    "container": "ghcr.io/parkervcp/steamcmd:debian",
    "entrypoint": "bash",
    "script": "#!/bin/bash\nset -euo pipefail\ncd /mnt/server\nsteamcmd +force_install_dir /mnt/server +login anonymous +app_update 896660 validate +quit\nmkdir -p /mnt/server/worlds_local\nchmod +x valheim_server.x86_64 || true\necho 'Valheim install complete.'\n"
  },
  "configFiles": [
    {
      "path": "start_server_settings.cfg",
      "parser": "file",
      "find": {}
    }
  ],
  "recCpuCores": 2,
  "recMemoryMb": 4096,
  "recDiskMb": 8192,
  "variables": [
    {
      "envName": "SERVER_NAME",
      "displayName": "Server Name",
      "description": "Display name shown in the in-game server browser.",
      "type": "STRING",
      "defaultValue": "A ReFx Hosting Valheim Server",
      "rules": {
        "required": true,
        "maxLength": 64
      },
      "userEditable": true,
      "userViewable": true,
      "sortOrder": 0
    },
    {
      "envName": "WORLD_NAME",
      "displayName": "World Name",
      "description": "Name of the world save to load or create.",
      "type": "STRING",
      "defaultValue": "Dedicated",
      "rules": {
        "required": true,
        "regex": "^[\\w-]+$"
      },
      "userEditable": true,
      "userViewable": true,
      "sortOrder": 1
    },
    {
      "envName": "SERVER_PASS",
      "displayName": "Server Password",
      "description": "Join password (minimum 5 characters). Required for non-public servers.",
      "type": "SECRET",
      "defaultValue": "",
      "rules": {
        "required": true,
        "minLength": 5
      },
      "userEditable": true,
      "userViewable": false,
      "sortOrder": 2
    },
    {
      "envName": "PUBLIC",
      "displayName": "Publicly Listed",
      "description": "1 = listed in the community browser, 0 = join by IP only.",
      "type": "ENUM",
      "defaultValue": "1",
      "rules": {
        "required": true,
        "options": [
          "1",
          "0"
        ]
      },
      "userEditable": true,
      "userViewable": true,
      "sortOrder": 3
    }
  ],
  "tags": [
    "viking",
    "co-op",
    "exploration"
  ],
  "longDescription": "Explore, build and conquer the tenth Norse world with friends on a dedicated Valheim server."
}
