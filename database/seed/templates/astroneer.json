{
  "name": "Astroneer",
  "slug": "astroneer",
  "author": "ops@refx.example",
  "description": "Space sandbox exploration. SteamCMD-installed dedicated server (Windows build via Proton).",
  "category": "sandbox",
  "deployMethods": [
    "DOCKER",
    "NATIVE_PROCESS"
  ],
  "supportsLinux": true,
  "supportsWindows": true,
  "dockerImages": {
    "Default": "ghcr.io/parkervcp/steamcmd:proton"
  },
  "steamAppId": 728470,
  "startupCommand": "wine AstroServer.exe",
  "startupDetect": "Full read of file successful",
  "stopCommand": "^C",
  "installScript": {
    "container": "ghcr.io/parkervcp/steamcmd:proton",
    "entrypoint": "bash",
    "script": "#!/bin/bash\nset -euo pipefail\nmkdir -p /mnt/server\ncd /mnt/server\nsteamcmd +@sSteamCmdForcePlatformType windows +force_install_dir /mnt/server +login anonymous +app_update 728470 validate +quit\necho 'Astroneer install complete.'\n"
  },
  "configFiles": [
    {
      "path": "Astro/Saved/Config/WindowsServer/AstroServerSettings.ini",
      "parser": "ini",
      "find": {}
    }
  ],
  "recCpuCores": 2,
  "recMemoryMb": 3072,
  "recDiskMb": 5120,
  "variables": [
    {
      "envName": "SERVER_NAME",
      "displayName": "Server Name",
      "description": "Name shown in the in-game server browser.",
      "type": "STRING",
      "defaultValue": "A ReFx Hosting Astroneer Server",
      "rules": {
        "required": true,
        "maxLength": 128
      },
      "userEditable": true,
      "userViewable": true,
      "sortOrder": 0
    },
    {
      "envName": "MAX_PLAYERS",
      "displayName": "Max Players",
      "description": "Maximum concurrent player slots.",
      "type": "NUMBER",
      "defaultValue": "8",
      "rules": {
        "required": true,
        "min": 1,
        "max": 24
      },
      "userEditable": true,
      "userViewable": true,
      "sortOrder": 1
    },
    {
      "envName": "OWNER_NAME",
      "displayName": "Owner Name",
      "description": "Player name granted server-owner permissions.",
      "type": "STRING",
      "defaultValue": "",
      "rules": {
        "maxLength": 64
      },
      "userEditable": true,
      "userViewable": true,
      "sortOrder": 2
    },
    {
      "envName": "SERVER_PASSWORD",
      "displayName": "Server Password",
      "description": "Leave blank for an open server.",
      "type": "SECRET",
      "defaultValue": "",
      "rules": {
        "maxLength": 64
      },
      "userEditable": true,
      "userViewable": false,
      "sortOrder": 3
    }
  ],
  "tags": [
    "sandbox",
    "exploration",
    "co-op",
    "multiplayer"
  ],
  "longDescription": "Reshape planets and automate bases with friends on a dedicated Astroneer server."
}
