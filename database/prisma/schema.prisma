// ============================================================================
// ReFx Hosting — Canonical Database Schema (PostgreSQL)
// ----------------------------------------------------------------------------
// This is the single source of truth for the platform's relational data model.
// The panel-api (NestJS) consumes it via Prisma Client. The node-agent (Go)
// reads a denormalized, scoped view delivered over the agent API; it never
// touches Postgres directly.
//
// Conventions:
//   * All primary keys are UUID v7 (time-sortable) generated app-side.
//   * Money is stored as integer minor units (cents) + ISO currency code.
//   * Soft-deletes use `deletedAt`; hard deletes are reserved for GDPR erasure.
//   * Every mutating action is mirrored into AuditLog.
// ============================================================================

generator client {
  provider = "prisma-client-js"
  // Full-text search is handled by OpenSearch (see docs/09-infrastructure.md),
  // so no Postgres FTS preview feature is required here.
  // (The "metrics" preview feature was removed in Prisma 7; it was unused here.)
}

datasource db {
  provider = "postgresql"
  // Prisma 7: the connection URL moved out of the schema. Migrate reads it from
  // prisma.config.ts; the runtime connects via the pg driver adapter (see
  // PrismaService). DATABASE_URL is supplied by the environment.
}

// ---------------------------------------------------------------------------
// Identity & Access
// ---------------------------------------------------------------------------

enum GlobalRole {
  CUSTOMER
  SUPPORT
  ADMIN
  OWNER
}

enum UserState {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

model User {
  id                String      @id @db.Uuid
  email             String      @unique
  emailVerifiedAt   DateTime?
  // Argon2id PHC string. Null for SSO-only accounts.
  passwordHash      String?
  firstName         String?
  lastName          String?
  globalRole        GlobalRole  @default(CUSTOMER)
  // Assigned RBAC role (granular permissions). Falls back to globalRole defaults
  // when null. Seeded/backfilled to the matching system role.
  roleId            String?     @db.Uuid
  role              Role?       @relation(fields: [roleId], references: [id])
  state             UserState   @default(PENDING_VERIFICATION)
  locale            String      @default("en")
  timezone          String      @default("UTC")
  avatarUrl         String?

  // Contact / billing address — self-service, all optional. Useful for support
  // and for billing/tax. No PII beyond what the customer chooses to provide.
  phone             String?
  addressLine1      String?
  addressLine2      String?
  city              String?
  region            String?     // state / province
  postalCode        String?
  country           String?     // ISO country code or name

  // Store credit (minor units, platform default currency). Applied to invoices.
  creditBalanceMinor Int        @default(0)
  creditTransactions CreditTransaction[]

  // Payment-gateway customer handle (e.g. Stripe "cus_..."), so saved cards can
  // be charged off-session at renewal. Created on first card save.
  gatewayCustomerId String?

  // Set when an admin issues a temporary password; the user is forced to choose
  // a new one on next login (cleared on any self-service password change/reset).
  mustChangePassword Boolean    @default(false)

  // MFA
  totpSecretEnc     String?     // AES-256-GCM encrypted TOTP seed
  totpEnabledAt     DateTime?
  webauthnCredentials WebAuthnCredential[]
  recoveryCodes     RecoveryCode[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordHistory         PasswordHistory[]

  // Relations
  ownedServers      Server[]    @relation("ServerOwner")
  subUserGrants     SubUser[]   @relation("SubUserUser")
  apiKeys           ApiKey[]
  sessions          Session[]
  invoices          Invoice[]
  paymentMethods    PaymentMethod[]
  subscriptions     Subscription[]
  tickets           Ticket[]    @relation("TicketRequester")
  assignedTickets   Ticket[]    @relation("TicketAssignee")
  ticketMessages    TicketMessage[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  pushTokens        PushToken[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  @@index([state])
  @@index([globalRole])
  @@index([roleId])
}

/// RBAC role: a named set of granular permission strings (see common/permissions).
/// System roles (owner/admin/support/customer) mirror the GlobalRole hierarchy
/// and can't be deleted; owners may create custom roles with any permission set.
model Role {
  id          String   @id @db.Uuid
  key         String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Session {
  id           String   @id @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash  String   // SHA-256 of refresh token
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  revokedAt    DateTime?
  // Set when this session was revoked specifically by refresh-token ROTATION
  // (vs. logout / password reset). Lets refresh tolerate a benign concurrent
  // refresh of a just-rotated token within a short grace window instead of
  // tripping reuse-detection and nuking the whole session family.
  rotatedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
}

/// APNs/FCM device token for mobile push. One row per device token; a token is
/// globally unique and re-assigned to whoever last registered it (shared devices).
/// Cascades on user delete. Pruned automatically when Apple reports it stale
/// (410 Unregistered / BadDeviceToken).
model PushToken {
  id        String   @id @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // "ios" (room for "android" later)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WebAuthnCredential {
  id            String   @id @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId  String   @unique
  publicKey     Bytes
  counter       BigInt   @default(0)
  transports    String[]
  label         String?
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?

  @@index([userId])
}

model RecoveryCode {
  id        String    @id @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Single-use, time-boxed password-reset token. Only the SHA-256 hash of the
// high-entropy random token is persisted; the plaintext is emailed to the user.
model PasswordResetToken {
  id        String    @id @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 of the plaintext reset token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Single-use, time-boxed email-verification token. Same shape/conventions as
// PasswordResetToken — only the SHA-256 hash is stored at rest.
model EmailVerificationToken {
  id        String    @id @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 of the plaintext verification token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Argon2id hashes of a user's RECENT past passwords, so a reset/change can
// refuse to reuse one. Only hashes are stored (never plaintext) — same
// sensitivity as User.passwordHash — and the app prunes to the last few rows
// per user, which bounds both storage and the (cost-bearing) verify loop.
model PasswordHistory {
  id           String   @id @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String // Argon2id PHC string of a previously-used password
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

enum ApiKeyScope {
  READ
  WRITE
  ADMIN
  // Narrow, read-only capability for the public status feed + /status/nodes
  // metrics (machine clients like the Helios Discord bot). A key bearing this
  // scope is ISOLATED to status routes — it cannot reach customer, billing or
  // admin data even though it is owned by a user. Enforced in
  // ApiKeyWriteScopeInterceptor + StatusReadGuard.
  STATUS_READ
}

model ApiKey {
  id           String       @id @db.Uuid
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  prefix       String       @unique   // first 8 chars, shown in UI
  keyHash      String                  // SHA-256 of full key
  scopes       ApiKeyScope[]
  // Optional per-key IP allowlist (CIDR).
  allowedIps   String[]
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime     @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Infrastructure: Nodes & Allocations
// ---------------------------------------------------------------------------

enum NodeOs {
  LINUX
  WINDOWS
}

enum NodeState {
  PROVISIONING
  ONLINE
  OFFLINE
  MAINTENANCE
  DEGRADED
}

model Region {
  id        String   @id @db.Uuid
  code      String   @unique   // e.g. "eu-central", "us-east"
  name      String
  country   String
  nodes     Node[]
  createdAt DateTime @default(now())
}

model Node {
  id            String     @id @db.Uuid
  name          String
  fqdn          String     @unique
  regionId      String     @db.Uuid
  region        Region     @relation(fields: [regionId], references: [id])
  os            NodeOs
  state         NodeState  @default(PROVISIONING)
  maintenance   Boolean    @default(false)

  // Agent connection
  agentVersion  String?
  // Bcrypt/argon hash of the per-node bootstrap token.
  tokenHash     String
  // Bootstrap token lifecycle. The token a node first registers with is
  // single-use and time-boxed: it must be presented before
  // bootstrapTokenExpiresAt and only once (bootstrapTokenUsedAt is stamped on a
  // successful register). Rotating the token (admin "regenerate") clears used +
  // sets a fresh expiry.
  bootstrapTokenExpiresAt DateTime?
  bootstrapTokenUsedAt    DateTime?
  daemonPort    Int        @default(8443)
  sftpPort      Int        @default(2022)
  scheme        String     @default("https")
  // Pinned agent TLS certificate (PEM) + its SHA-256 fingerprint. When set and
  // AGENT_TLS_PINNING is on, the panel verifies the agent against THIS cert
  // (defeats MITM on the self-signed control channel). Populated via the admin
  // "pin certificate" action (trust-on-first-use).
  agentCertPem    String?
  agentCertSha256 String?

  // Public port range the panel auto-assigns from for this node's server
  // allocations (primary game port + per-game query/RCON/etc.). Configurable per
  // node so operators can match their firewall / port-forwarding rules.
  allocationPortStart Int   @default(25565)
  allocationPortEnd   Int   @default(25999)

  // Optional wildcard "game domain" for branded per-server connection addresses
  // (GPortal-style). When set (e.g. "fra.refx.gg") and a matching wildcard DNS
  // record (*.fra.refx.gg -> this node's public IP) exists, each new server is
  // assigned an allocation alias "<shortId>.<gameDomain>" that customers see
  // instead of the raw node IP. Empty -> servers advertise the node fqdn.
  gameDomain    String?

  // Capacity (advertised by agent, overridable by admin)
  cpuCores      Int
  memoryMb      Int
  diskMb        Int
  // Overcommit ratios (1.0 = no overcommit)
  cpuOvercommit Float      @default(1.0)
  memOvercommit Float      @default(1.0)

  // Whether this node can host WEB_APP servers — i.e. it runs Caddy on :80/:443
  // and has the reverse-proxy wiring the web product needs. The scheduler only
  // places web servers on supportsWeb nodes; game/voice servers ignore it.
  supportsWeb   Boolean    @default(false)

  // Economics: what this node costs YOU per month (the hardware/hosting bill),
  // in integer minor units (cents) + ISO currency — same money convention as
  // everywhere else. Optional; set per node in the admin UI so the panel can
  // show live per-node margin (this cost vs. the estimated monthly revenue of
  // the servers placed on the node). `provider` is a free-text label for the
  // box (e.g. "OVH Rise-3 · Hillsboro").
  monthlyCostMinor Int?
  costCurrency     String  @default("USD")
  provider         String?

  servers       Server[]
  allocations   Allocation[]
  heartbeats    NodeHeartbeat[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  @@index([regionId])
  @@index([state])
}

model NodeHeartbeat {
  id          String   @id @db.Uuid
  nodeId      String   @db.Uuid
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  cpuPct      Float
  memUsedMb   Int
  diskUsedMb  Int
  netRxBytes  BigInt
  netTxBytes  BigInt
  containers  Int
  recordedAt  DateTime @default(now())

  @@index([nodeId, recordedAt])
}

// One IP:port a server can bind. Primary allocation = default game port.
model Allocation {
  id        String   @id @db.Uuid
  nodeId    String   @db.Uuid
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  ip        String
  port      Int
  alias     String?
  // Purpose marker for secondary allocations (e.g. "voicechat" for a dedicated
  // Simple Voice Chat UDP port). NULL for the primary game-port allocation.
  label     String?
  serverId  String?  @db.Uuid
  server    Server?  @relation(fields: [serverId], references: [id])
  isPrimary Boolean  @default(false)

  @@unique([nodeId, ip, port])
  @@index([serverId])
}

// ---------------------------------------------------------------------------
// Game Templates ("Eggs" equivalent) & Categories
// ---------------------------------------------------------------------------

enum DeployMethod {
  DOCKER
  NATIVE_PROCESS
  WINDOWS_CONTAINER
  SANDBOX
}

model GameCategory {
  id       String         @id @db.Uuid
  name     String
  slug     String         @unique
  iconUrl  String?
  templates GameTemplate[]
}

// A template is a versioned, JSON-driven game definition. Admins author these
// in the panel with no code changes (Pterodactyl "egg" superset).
model GameTemplate {
  id              String         @id @db.Uuid
  categoryId      String?        @db.Uuid
  category        GameCategory?  @relation(fields: [categoryId], references: [id])
  name            String         // "Minecraft: Paper"
  slug            String         @unique
  author          String
  description     String?
  version         Int            @default(1)
  // GAME (default) or WEB (app-container hosting). Splits storefront/dashboard.
  kind            TemplateKind   @default(GAME)

  // Supported deployment + OS matrix
  deployMethods   DeployMethod[]
  supportsLinux   Boolean        @default(true)
  supportsWindows Boolean        @default(false)

  // Docker image(s): map of tag-label -> image ref
  dockerImages    Json           // {"Java 21":"ghcr.io/refx/minecraft:21"}
  // Native install (used for NATIVE_PROCESS): SteamCMD app id, etc.
  steamAppId      Int?

  // Startup command template with {{VAR}} interpolation.
  startupCommand  String
  // Regex/string the agent watches stdout for to mark "running".
  startupDetect   String?
  stopCommand     String         @default("^C") // or RCON "stop", signal, etc.

  // Lifecycle scripts. Each: {container, entrypoint, script}
  installScript   Json
  // Config files to render/replace on (re)install. Array of file specs.
  configFiles     Json           @default("[]")

  // Recommended resources (used to size products / warn admins)
  recCpuCores     Float          @default(1)
  recMemoryMb     Int            @default(1024)
  recDiskMb       Int            @default(5120)

  // Steam Workshop: when true, servers on this template expose a Workshop tab to
  // manage Workshop items/collections. `workshopAppId` is the Steam app whose
  // Workshop to use (often == steamAppId; some games publish under a different
  // app). Applied via the egg's startup/install variables (WORKSHOP_*).
  supportsWorkshop Boolean       @default(false)
  workshopAppId    Int?

  // ---- Public storefront metadata ----------------------------------------
  // Opt-in: a template is hidden from the public storefront until an admin
  // publishes it (it always remains visible/usable in the admin panel).
  isPublished     Boolean        @default(false)
  featured        Boolean        @default(false)
  sortOrder       Int            @default(0)
  longDescription String?        // marketing copy for the game detail page
  cardImageUrl    String?        // homepage/catalog card art
  heroImageUrl    String?        // detail-page hero/background
  iconUrl         String?        // small logo/icon
  tags            String[]       @default([]) // free-form storefront tags

  variables       TemplateVariable[]
  servers         Server[]
  products        Product[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum VariableType {
  STRING
  NUMBER
  BOOLEAN
  ENUM
  SECRET
}

model TemplateVariable {
  id           String       @id @db.Uuid
  templateId   String       @db.Uuid
  template     GameTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  envName      String       // SERVER_JARFILE
  displayName  String       // "Server JAR file"
  description  String?
  type         VariableType @default(STRING)
  defaultValue String?
  // JSON-encoded validation rules (min/max/regex/options).
  rules        Json         @default("{}")
  userEditable Boolean      @default(true)
  userViewable Boolean      @default(true)
  sortOrder    Int          @default(0)

  @@unique([templateId, envName])
}

// Tombstone for an egg an admin deleted in the panel. The seed re-imports any
// egg JSON under database/seed/templates whose template row is missing, so a
// deleted egg would otherwise reappear on the next reseed. The seed skips slugs
// listed here; re-creating an egg with the same slug in the panel clears it.
model RetiredEgg {
  id        String   @id @db.Uuid
  slug      String   @unique
  name      String?
  retiredAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Servers (the core GPortal-style identity that survives game switching)
// ---------------------------------------------------------------------------

enum ServerState {
  INSTALLING
  OFFLINE
  STARTING
  RUNNING
  STOPPING
  CRASHED
  SUSPENDED
  REINSTALLING
  SWITCHING_GAME
  TRANSFERRING
  // Created and port-reserved, but NOT installed — awaiting first payment.
  PENDING_PAYMENT
}

/// Distinguishes a voice (e.g. TeamSpeak 3) server from a game server. Set ONCE
/// at creation and treated as immutable — a voice server can never be
/// game-switched — so this is the AUTHORITATIVE discriminator for all
/// game-vs-voice separation (it replaces the old template-slug heuristic).
enum ServerType {
  GAME_SERVER
  VOICE_SERVER
  WEB_APP
  // Discord/application bot container (runs user-supplied bot code).
  BOT_APP
}

/// GameTemplate kind — splits the storefront/dashboard into games vs web hosting.
/// A WEB template provisions an app container (WordPress, static nginx, Node) and
/// its servers are ServerType.WEB_APP with Domain rows + reverse-proxy routing.
enum TemplateKind {
  GAME
  WEB
  // Application/bot hosting (e.g. a Discord bot): runs user code in a chosen
  // runtime image. Surfaced under the web-hosting catalog.
  BOT
}

/// SSL/issuance state for a custom Domain mapped to a web app.
enum SslStatus {
  PENDING
  ACTIVE
  FAILED
}

model Server {
  id              String        @id @db.Uuid
  // Short, user-facing identifier (e.g. "a1b2c3d4") used in URLs/SFTP user.
  shortId         String        @unique
  // Purchased custom address label (replaces shortId in the advertised
  // <label>.<node.gameDomain> alias). Globally unique; NULL = default address.
  vanityLabel     String?       @unique
  name            String
  description     String?

  ownerId         String        @db.Uuid
  owner           User          @relation("ServerOwner", fields: [ownerId], references: [id])

  nodeId          String        @db.Uuid
  node            Node          @relation(fields: [nodeId], references: [id])

  // Current game template + version pin. NULL while between games.
  templateId      String?       @db.Uuid
  template        GameTemplate? @relation(fields: [templateId], references: [id])
  templateVersion Int?

  state           ServerState   @default(INSTALLING)
  deployMethod    DeployMethod  @default(DOCKER)
  // Voice vs game — authoritative discriminator, set at creation, never changes.
  serverType      ServerType    @default(GAME_SERVER)

  // Resource limits (the customer's plan; survives game switch)
  cpuCores        Float
  memoryMb        Int
  swapMb          Int           @default(0)
  diskMb          Int
  ioWeight        Int           @default(500)
  slots           Int?          // optional player-slot cap
  bandwidthMbps   Int?

  // Runtime config
  startupCommand  String?
  environment     Json          @default("{}") // resolved env var values
  dockerImage     String?

  // Billing linkage
  subscriptionId  String?       @db.Uuid
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  suspendedAt     DateTime?

  // SFTP credentials are derived; password is per-server, rotated on demand.
  sftpPasswordEnc String?

  // The customer's OWN Steam login for downloading Workshop content that needs an
  // account that owns the game (e.g. Arma 3). Password is AES-256-GCM encrypted;
  // used at install time on the node and never returned to the client.
  steamUsername   String?
  steamPasswordEnc String?
  // A one-time Steam Guard code supplied for the NEXT install (e.g. emailed/app
  // code for a Guard-protected account). Consumed + cleared by the install job;
  // after a successful guarded login the node remembers the machine (sentry).
  steamGuardCode  String?

  allocations     Allocation[]
  pendingVanityAddress PendingVanityAddress?
  backups         Backup[]
  databases       ServerDatabase[]
  schedules       Schedule[]
  subUsers        SubUser[]
  variables       ServerVariable[]
  workshopMods    WorkshopMod[]
  gameHistory     GameSwitchLog[]
  transfers       ServerTransfer[]
  stats           ServerStat[]
  domains         Domain[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([ownerId])
  @@index([nodeId])
  @@index([state])
  @@index([serverType])
}

/// A hostname mapped to a WEB_APP server, fronted by the node's reverse proxy
/// (Caddy) which terminates TLS. SSL is issued per-domain via Let's Encrypt once
/// the hostname's DNS resolves to the node; sslStatus tracks issuance.
model Domain {
  id         String    @id @db.Uuid
  serverId   String    @db.Uuid
  server     Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  hostname   String    @unique
  isPrimary  Boolean   @default(false)
  sslStatus  SslStatus @default(PENDING)
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([serverId])
}

enum WorkshopKind {
  ITEM
  COLLECTION
}

/// A Steam Workshop item or collection attached to a server. Applied to the
/// running server via the egg's WORKSHOP_* startup/install variables (collection
/// id for runtime-collection games like Garry's Mod; the item list for
/// steamcmd-download games like Arma 3).
model WorkshopMod {
  id         String       @id @db.Uuid
  serverId   String       @db.Uuid
  server     Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  workshopId String       // numeric Steam published-file id
  name       String?
  kind       WorkshopKind @default(ITEM)
  enabled    Boolean      @default(true)
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())

  @@unique([serverId, workshopId])
  @@index([serverId])
}

// Per-server override of a template variable's value.
model ServerVariable {
  id        String   @id @db.Uuid
  serverId  String   @db.Uuid
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  envName   String
  value     String

  @@unique([serverId, envName])
}

// Audit of every game switch (keeps server identity, swaps software).
model GameSwitchLog {
  id            String   @id @db.Uuid
  serverId      String   @db.Uuid
  server        Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  fromTemplate  String?
  toTemplate    String
  preservedData Boolean  @default(false)
  performedById String   @db.Uuid
  createdAt     DateTime @default(now())

  @@index([serverId])
}

// Lifecycle of an admin-initiated server transfer between nodes. Terminal
// states are SUCCEEDED / FAILED; everything else is in-flight.
enum TransferState {
  PENDING
  SNAPSHOTTING
  PROVISIONING
  RESTORING
  FINALIZING
  SUCCEEDED
  FAILED
}

// An admin-only, Pterodactyl-style move of a server from one node to another.
// The orchestration (snapshot on source → provision on dest → restore →
// repoint → delete source) runs in a BullMQ job; this row tracks its progress
// and is the source of truth the UI polls. The server keeps its identity
// (shortId, SFTP, backups, subscription) throughout — only its nodeId changes.
model ServerTransfer {
  id         String        @id @db.Uuid
  serverId   String        @db.Uuid
  server     Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  fromNodeId String        @db.Uuid
  toNodeId   String        @db.Uuid
  // The snapshot taken on the source node and restored on the destination.
  backupId   String?       @db.Uuid
  state      TransferState @default(PENDING)
  error      String?
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([serverId])
  @@index([state])
}

model ServerStat {
  id          String   @id @db.Uuid
  serverId    String   @db.Uuid
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  cpuPct      Float
  memUsedMb   Int
  diskUsedMb  Int
  netRxBytes  BigInt
  netTxBytes  BigInt
  players     Int?
  recordedAt  DateTime @default(now())

  @@index([serverId, recordedAt])
}

enum SubUserState {
  ACTIVE
  REVOKED
}

model SubUser {
  id          String       @id @db.Uuid
  serverId    String       @db.Uuid
  server      Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  userId      String       @db.Uuid
  user        User         @relation("SubUserUser", fields: [userId], references: [id], onDelete: Cascade)
  // Granular permissions, e.g. ["console.command","files.read","backup.create"]
  permissions String[]
  state       SubUserState @default(ACTIVE)
  createdAt   DateTime     @default(now())

  @@unique([serverId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Backups, Databases, Schedules
// ---------------------------------------------------------------------------

enum BackupState {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum BackupStorage {
  LOCAL
  S3
}

model Backup {
  id          String        @id @db.Uuid
  serverId    String        @db.Uuid
  server      Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name        String
  state       BackupState   @default(PENDING)
  storage     BackupStorage @default(S3)
  // Live progress (0–100) reported by the agent while the backup runs.
  progressPct Int           @default(0)
  // Object key / local path
  location    String?
  sizeBytes   BigInt        @default(0)
  checksum    String?       // sha256
  isLocked    Boolean       @default(false) // protected from rotation
  ignoredFiles String[]
  error       String?
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([serverId])
}

enum DbEngine {
  MYSQL
  MARIADB
  POSTGRESQL
}

model ServerDatabase {
  id           String        @id @db.Uuid
  serverId     String        @db.Uuid
  server       Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  // Which shared DB host this was provisioned on (nullable for legacy rows).
  hostId       String?       @db.Uuid
  dbHost       DatabaseHost? @relation(fields: [hostId], references: [id])
  engine       DbEngine
  name         String
  username     String
  passwordEnc  String
  host         String
  port         Int
  remoteAccess String        @default("%") // allowed host pattern
  createdAt    DateTime      @default(now())

  @@unique([serverId, name])
}

// A shared database server the panel provisions per-server databases on. The
// admin connection (host/port/username/passwordEnc) is used to run the
// CREATE/DROP/GRANT DDL; `publicHost` is what customers connect to (which may be
// a public hostname/IP different from the internal admin `host`).
model DatabaseHost {
  id           String           @id @db.Uuid
  name         String
  engine       DbEngine         @default(MARIADB)
  host         String // admin connection host (panel -> DB server)
  port         Int              @default(3306)
  username     String // admin/provisioner user
  passwordEnc  String // AES-256-GCM
  publicHost   String // hostname/IP customers connect to
  maxDatabases Int              @default(500)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  databases    ServerDatabase[]
}

model Schedule {
  id           String   @id @db.Uuid
  serverId     String   @db.Uuid
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name         String
  cron         String   // standard 5-field cron
  isActive     Boolean  @default(true)
  onlyWhenOnline Boolean @default(false)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  tasks        ScheduleTask[]
  createdAt    DateTime @default(now())

  @@index([serverId])
  @@index([nextRunAt])
}

enum ScheduleAction {
  COMMAND
  POWER       // start/stop/restart
  BACKUP
}

model ScheduleTask {
  id           String         @id @db.Uuid
  scheduleId   String         @db.Uuid
  schedule     Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  action       ScheduleAction
  payload      String         // command text, "restart", etc.
  timeOffsetMs Int            @default(0) // delay after previous task
  sortOrder    Int            @default(0)
  continueOnFailure Boolean   @default(false)
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

enum ProductType {
  GAME_SERVER
  VOICE_SERVER
  VPS
  DEDICATED
  ADDON
  WEB_HOSTING
  // Discord/application bot hosting (runtime container for user bot code).
  BOT_HOSTING
}

/// How a product is configured + priced at order time.
///   HARDWARE_TIER — game servers: customer picks a Low/Mid/High HardwareTier
///     (fixed RAM/CPU/disk); price = the chosen tier's price for the interval.
///   PER_SLOT      — voice servers (e.g. TeamSpeak 3): customer picks a slot
///     count; price = per-slot price × slots; resources scale per slot.
enum BillingModel {
  HARDWARE_TIER
  PER_SLOT
}

enum BillingInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model Product {
  id            String          @id @db.Uuid
  type          ProductType
  // Configuration/pricing model. HARDWARE_TIER products carry HardwareTiers (and
  // price per tier); PER_SLOT products use the per-slot block below. Kept in
  // lock-step with `perSlot` (perSlot == billingModel == PER_SLOT).
  billingModel  BillingModel    @default(HARDWARE_TIER)
  name          String
  slug          String          @unique
  description   String?
  isActive      Boolean         @default(true)

  // Resource template applied to provisioned servers. For HARDWARE_TIER products
  // these are a fallback; the chosen HardwareTier supplies the real limits.
  cpuCores      Float?
  memoryMb      Int?
  diskMb        Int?
  slots         Int?
  // Templates allowed on this product (game switching whitelist). Empty = all.
  allowedTemplateIds String[]

  // Hardware tiers (Low/Mid/High) for HARDWARE_TIER game products. Each tier is a
  // fixed RAM/CPU/disk package with its own per-interval Prices.
  hardwareTiers HardwareTier[]

  // GPortal-style per-slot pricing (PER_SLOT products, e.g. voice/TeamSpeak 3).
  // The order page shows a slot slider and the invoice is `Price.amountMinor
  // (per slot, per interval) x slots`; provisioned resources are the per-slot
  // values x slots. The product is bound to one game/voice template
  // (gameTemplateId) so the storefront can offer it per-product.
  perSlot         Boolean @default(false)
  gameTemplateId  String? @db.Uuid
  gameTemplate    GameTemplate? @relation(fields: [gameTemplateId], references: [id])
  minSlots        Int     @default(1)
  maxSlots        Int     @default(100)
  slotStep        Int     @default(1)
  cpuPerSlot      Float   @default(0)
  memoryMbPerSlot Int     @default(0)
  diskMbPerSlot   Int     @default(0)

  prices        Price[]
  subscriptions Subscription[]

  // PayPal catalog product id (lazily created for recurring PayPal subscriptions).
  paypalProductId String?

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

/// A fixed hardware package (Low/Mid/High) under a HARDWARE_TIER game Product.
/// Resources (cpu/mem/disk) and pricing are configurable per tier from the admin
/// panel — never hardcoded in the frontend. `recommendedPlayers` is informational
/// only (NOT the billing basis). Pricing lives on Price rows scoped to the tier.
model HardwareTier {
  id                 String   @id @db.Uuid
  productId          String   @db.Uuid
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name               String   // "Low Tier" / "Mid Tier" / "High Tier"
  description        String?
  cpuCores           Float    @default(1)
  memoryMb           Int      @default(1024)
  diskMb             Int      @default(5120)
  // Informational only — shown on the storefront card, never used for pricing.
  recommendedPlayers Int?
  isRecommended      Boolean  @default(false)
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)

  prices             Price[]
  subscriptions      Subscription[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([productId])
}

model Price {
  id          String          @id @db.Uuid
  productId   String          @db.Uuid
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  // When set, this price belongs to a specific HardwareTier (game tiers price
  // per tier). NULL = product-level price (PER_SLOT/voice products).
  hardwareTierId String?      @db.Uuid
  hardwareTier   HardwareTier? @relation(fields: [hardwareTierId], references: [id], onDelete: Cascade)
  interval    BillingInterval
  currency    String          @default("USD")
  amountMinor Int             // cents
  // External processor price IDs
  stripePriceId String?
  // PayPal billing-plan id (lazily created for recurring PayPal subscriptions).
  paypalPlanId  String?
  isActive    Boolean         @default(true)

  @@unique([productId, hardwareTierId, interval, currency])
  @@index([hardwareTierId])
}

enum SubscriptionState {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
  EXPIRED
}

model Subscription {
  id              String            @id @db.Uuid
  userId          String            @db.Uuid
  user            User              @relation(fields: [userId], references: [id])
  productId       String            @db.Uuid
  product         Product           @relation(fields: [productId], references: [id])
  priceId         String            @db.Uuid
  // Chosen hardware tier for HARDWARE_TIER game orders (drives provisioned
  // resources + the renewal price). NULL for PER_SLOT/voice orders.
  hardwareTierId  String?           @db.Uuid
  hardwareTier    HardwareTier?     @relation(fields: [hardwareTierId], references: [id])
  interval        BillingInterval
  slots           Int               @default(1)
  state           SubscriptionState @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean        @default(false)
  autoRenew       Boolean           @default(true)
  // Set when the upcoming-renewal reminder was emailed for the CURRENT period;
  // cleared when the period rolls so the next period reminds again.
  renewalReminderSentAt DateTime?

  // Processor linkage
  gateway         String            // "stripe" | "paypal"
  gatewaySubId    String?

  servers         Server[]
  invoices        Invoice[]
  pendingPlanChange PendingPlanChange?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@index([state])
}

/// A plan change (upgrade/downgrade) staged on a subscription but NOT yet applied
/// to the running server. UPGRADES are gated on payment: `invoice` must be PAID
/// before the change applies — the server stays on its OLD configuration until
/// then. DOWNGRADES carry no invoice and apply at the next renewal
/// (`applyAtPeriodEnd`). At most one pending change per subscription.
// A purchased-but-unpaid custom server address. Created when the customer
// buys a vanity label; the label is reserved (unique) while the gating invoice
// is OPEN. Applied by markInvoicePaid on the OPEN->PAID transition (sets
// Server.vanityLabel + rewrites allocation aliases); released when the invoice
// is voided. Mirrors the PendingPlanChange pay-then-apply pattern.
model PendingVanityAddress {
  id        String   @id @db.Uuid
  serverId  String   @unique @db.Uuid
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  // The gating invoice; NULL only during the brief claim-then-invoice window.
  invoiceId String?  @unique @db.Uuid
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  // Normalized label, reserved while payment is pending.
  label     String   @unique
  createdAt DateTime @default(now())
}

model PendingPlanChange {
  id               String        @id @db.Uuid
  subscriptionId   String        @unique @db.Uuid
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  // The upgrade invoice that must clear before applying. NULL for a downgrade.
  invoiceId        String?       @unique @db.Uuid
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  applyAtPeriodEnd Boolean       @default(false)

  // Target configuration to apply once the gating condition is met.
  priceId          String        @db.Uuid
  hardwareTierId   String?       @db.Uuid
  slots            Int
  cpuCores         Float
  memoryMb         Int
  diskMb           Int

  createdAt        DateTime      @default(now())
}

enum InvoiceState {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
  REFUNDED
}

model Invoice {
  id             String        @id @db.Uuid
  number         String        @unique // human-readable, e.g. INV-2026-000123
  userId         String        @db.Uuid
  user           User          @relation(fields: [userId], references: [id])
  subscriptionId String?       @db.Uuid
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  state          InvoiceState  @default(DRAFT)
  currency       String        @default("USD")

  subtotalMinor  Int
  discountMinor  Int           @default(0) // coupon discount applied to subtotal
  couponCode     String?       // the coupon applied, if any
  taxMinor       Int           @default(0)
  totalMinor     Int
  amountPaidMinor Int          @default(0)

  // Tax detail
  taxType        String?       // VAT | GST | US_SALES_TAX
  taxRatePct     Float?
  taxRegion      String?
  taxIdNumber    String?       // customer VAT/GST id

  gateway        String?
  gatewayInvoiceId String?
  pdfUrl         String?

  dueAt          DateTime?
  paidAt         DateTime?
  lineItems      InvoiceLineItem[]
  payments       Payment[]
  pendingPlanChange PendingPlanChange?
  pendingVanityAddress PendingVanityAddress?

  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([state])
}

// ---- Coupons & gift cards --------------------------------------------------

enum CouponKind {
  PERCENT
  FIXED
}

model Coupon {
  id               String     @id @db.Uuid
  code             String     @unique // stored uppercase
  description      String?
  kind             CouponKind
  value            Int        // PERCENT: 1-100 ; FIXED: minor units (cents)
  currency         String     @default("USD")
  minSubtotalMinor Int?       // minimum order subtotal to qualify
  maxRedemptions   Int?       // global cap (null = unlimited)
  timesRedeemed    Int        @default(0)
  maxPerUser       Int?       // per-customer cap (null = unlimited)
  startsAt         DateTime?
  expiresAt        DateTime?
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  redemptions      CouponRedemption[]
}

model CouponRedemption {
  id          String   @id @db.Uuid
  couponId    String   @db.Uuid
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId      String   @db.Uuid
  invoiceId   String?  @db.Uuid
  amountMinor Int      // discount granted
  createdAt   DateTime @default(now())

  @@index([couponId])
  @@index([userId])
}

model GiftCard {
  id                  String   @id @db.Uuid
  code                String   @unique
  initialBalanceMinor Int
  balanceMinor        Int      // remaining
  currency            String   @default("USD")
  isActive            Boolean  @default(true)
  expiresAt           DateTime?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transactions        GiftCardTransaction[]
}

model GiftCardTransaction {
  id          String   @id @db.Uuid
  giftCardId  String   @db.Uuid
  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  userId      String   @db.Uuid
  invoiceId   String?  @db.Uuid
  amountMinor Int      // negative = spend, positive = top-up/refund
  createdAt   DateTime @default(now())

  @@index([giftCardId])
}

enum CreditReason {
  ADMIN_GRANT
  REFUND
  GIFT_CARD
  INVOICE_PAYMENT
  ADJUSTMENT
}

model CreditTransaction {
  id          String       @id @db.Uuid
  userId      String       @db.Uuid
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountMinor Int          // positive = credit added, negative = spent
  reason      CreditReason @default(ADJUSTMENT)
  note        String?
  invoiceId   String?      @db.Uuid
  actorId     String?      @db.Uuid // admin who made the adjustment, if any
  createdAt   DateTime     @default(now())

  @@index([userId])
}

model InvoiceLineItem {
  id          String   @id @db.Uuid
  invoiceId   String   @db.Uuid
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int      @default(1)
  unitMinor   Int
  amountMinor Int
}

enum PaymentState {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model PaymentMethod {
  id          String   @id @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gateway     String   // stripe | paypal
  gatewayRef  String   // pm_xxx / billing agreement id
  brand       String?  // visa, paypal
  last4       String?
  expMonth    Int?
  expYear     Int?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Payment {
  id          String       @id @db.Uuid
  invoiceId   String       @db.Uuid
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  gateway     String
  gatewayRef  String
  amountMinor Int
  currency    String
  state       PaymentState @default(PENDING)
  failureReason String?
  createdAt   DateTime     @default(now())

  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// Support / Helpdesk
// ---------------------------------------------------------------------------

enum TicketState {
  OPEN
  PENDING_CUSTOMER
  PENDING_AGENT
  RESOLVED
  CLOSED
  ARCHIVED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model TicketCategory {
  id      String   @id @db.Uuid
  name    String
  slug    String   @unique
  // SLA targets in minutes
  slaFirstResponseMin Int @default(240)
  slaResolutionMin    Int @default(2880)
  tickets TicketMessage[] @ignore
}

model Ticket {
  id           String         @id @db.Uuid
  number       Int            @unique @default(autoincrement())
  subject      String
  requesterId  String         @db.Uuid
  requester    User           @relation("TicketRequester", fields: [requesterId], references: [id])
  assigneeId   String?        @db.Uuid
  assignee     User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  categoryId   String?        @db.Uuid
  state        TicketState    @default(OPEN)
  priority     TicketPriority @default(NORMAL)

  // SLA bookkeeping
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  slaBreached     Boolean     @default(false)

  messages     TicketMessage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([state])
  @@index([assigneeId])
}

model TicketMessage {
  id          String          @id @db.Uuid
  ticketId    String          @db.Uuid
  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String          @db.Uuid
  author      User            @relation(fields: [authorId], references: [id])
  body        String
  isInternal  Boolean         @default(false) // internal note, hidden from customer
  attachments TicketAttachment[]
  category    TicketCategory? @relation(fields: [categoryId], references: [id])
  categoryId  String?         @db.Uuid
  createdAt   DateTime        @default(now())

  @@index([ticketId])
}

model TicketAttachment {
  id         String        @id @db.Uuid
  messageId  String        @db.Uuid
  message    TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName   String
  objectKey  String
  sizeBytes  BigInt
  mimeType   String
  createdAt  DateTime      @default(now())
}

model CannedResponse {
  id        String   @id @db.Uuid
  title     String
  body      String
  tags      String[]
  createdAt DateTime @default(now())
}

model KbArticle {
  id          String   @id @db.Uuid
  slug        String   @unique
  title       String
  body        String   // markdown
  category    String?
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Platform: Audit, Notifications, Alerts
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @db.Uuid
  actorId    String?  @db.Uuid
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String   // "server.power.start"
  targetType String   // "Server"
  targetId   String?
  metadata   Json     @default("{}")
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

model Notification {
  id        String              @id @db.Uuid
  userId    String              @db.Uuid
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime            @default(now())

  @@index([userId, readAt])
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model GlobalAlert {
  id        String        @id @db.Uuid
  severity  AlertSeverity @default(INFO)
  title     String
  body      String
  isActive  Boolean       @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime      @default(now())
}

// Public, marketing/status notices shown on the customer-facing storefront.
// Deliberately separate from GlobalAlert (which targets the internal dashboard)
// so the two surfaces never interfere.
enum HomepageAlertType {
  INFO
  SUCCESS
  WARNING
  DANGER
  PROMO
}

model HomepageAlert {
  id          String            @id @db.Uuid
  type        HomepageAlertType @default(INFO)
  title       String
  body        String
  isActive    Boolean           @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  ctaLabel    String?
  ctaUrl      String?
  dismissible Boolean           @default(true)
  priority    Int               @default(0) // higher shows first
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

/// Lifecycle stage of a status incident (mirrors the public timeline).
enum IncidentStatus {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

/// How severely an incident impacts the affected component(s).
enum IncidentImpact {
  MAINTENANCE
  DEGRADED
  OUTAGE
}

/// An operator-posted status incident shown on the public /status page. While
/// unresolved it drives the affected components' displayed status (worst of the
/// auto-derived health and the incident impact). `components` holds component
/// keys: "panel-api" | "web" | "nodes" | "ios-app".
model StatusIncident {
  id          String                 @id @db.Uuid
  title       String
  status      IncidentStatus         @default(INVESTIGATING)
  impact      IncidentImpact         @default(DEGRADED)
  components  String[]
  startedAt   DateTime               @default(now())
  resolvedAt  DateTime?
  updates     StatusIncidentUpdate[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([resolvedAt])
}

/// A timeline entry on an incident (Investigating → Identified → … → Resolved).
model StatusIncidentUpdate {
  id         String         @id @db.Uuid
  incidentId String         @db.Uuid
  incident   StatusIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  status     IncidentStatus
  body       String
  createdAt  DateTime       @default(now())

  @@index([incidentId])
}

/// Outbound webhook subscription for real-time status pushes (e.g. the Helios
/// Discord bot). The panel POSTs a signed payload on component status changes and
/// incident create/update/resolve. `secret` is the HMAC signing key, AES-256-GCM
/// encrypted at rest (decrypted only to sign). Payloads carry ONLY public
/// status/incident fields — never customer/billing/server data.
model StatusWebhook {
  id             String   @id @db.Uuid
  url            String
  /// AES-256-GCM ciphertext of the shared signing secret.
  secretEnc      String
  /// Event types to deliver; empty = all status events.
  events         String[]
  isActive       Boolean  @default(true)
  description    String?
  lastDeliveryAt DateTime?
  /// HTTP status of the most recent delivery attempt (null until first send).
  lastStatus     Int?
  createdById    String?  @db.Uuid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

/// Admin-curated team member for the public "Meet the team" page. Not tied to a
/// user account — purely marketing content (name, title, bio, avatar).
model StaffMember {
  id        String   @id @db.Uuid
  name      String
  title     String   // role/title, e.g. "Founder" / "Support Lead"
  bio       String?
  avatarUrl String?
  // Optional public link (e.g. Discord/profile).
  link      String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

/// Key/value platform configuration editable at runtime (e.g. payment-gateway
/// credentials). Secret values are stored AES-256-GCM-encrypted (encrypted=true).
model PlatformSetting {
  key       String   @id
  value     String
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
