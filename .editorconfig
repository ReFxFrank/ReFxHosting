# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{ps1,psm1}]
indent_size = 4
end_of_line = crlf

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2
