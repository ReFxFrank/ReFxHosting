# =============================================================================
# ReFx Hosting — PRODUCTION environment template
# -----------------------------------------------------------------------------
# Copy to `.env` on the production host and fill EVERY value marked "REQUIRED".
# Never commit the real `.env`. The panel runs a boot-time preflight
# (config/preflight.ts) that REFUSES to start if the security-critical values
# below are weak/default — so this template exists to get them right the first
# time. Override the refusal only in an emergency with ALLOW_INSECURE_CONFIG=true.
#
# Generate secrets:
#   SECRETS_ENC_KEY : openssl rand -hex 32   (exactly 64 hex chars)
#   JWT_* secrets   : openssl rand -hex 48   (use a DIFFERENT value for each)
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production

# ---- Public URLs (REQUIRED, must be https) ----------------------------------
# The website origin users open in a browser. Used for email links, WebAuthn,
# redirects. MUST be https in production.
PANEL_URL=https://refx.gg
# Every browser origin allowed to call the API (CORS). List them explicitly —
# NEVER use "*". Include www if you serve it.
CORS_ORIGINS=https://refx.gg,https://www.refx.gg
# Baked into the web bundle at BUILD time — set before `docker compose build web`.
# Its scheme MUST match the site (https page cannot call an http API).
NEXT_PUBLIC_API_URL=https://api.refx.gg
# WebAuthn relying party — your registrable domain (NOT localhost).
PANEL_RP_ID=refx.gg
PANEL_RP_NAME=ReFx Hosting

# Brand/domain shown on the public legal/marketing pages (web, build-time).
NEXT_PUBLIC_BRAND_NAME=ReFx Hosting
NEXT_PUBLIC_SITE_DOMAIN=refx.gg
# App Store / TestFlight link (until set, the badge renders "Coming soon").
NEXT_PUBLIC_APP_STORE_URL=

# ---- Legal / policy pages (web, BUILD-time) ---------------------------------
# Any left blank renders a {{PLACEHOLDER}} verbatim on the public page — a visible
# "fill me in" reminder. Have the policy text reviewed by a lawyer before launch.
# Entity name + address typically wait until the legal entity is formed.
NEXT_PUBLIC_LEGAL_ENTITY=                 # e.g. ReFx Hosting LLC
NEXT_PUBLIC_LEGAL_ADDRESS=                # registered business address
NEXT_PUBLIC_CONTACT_EMAIL=               # e.g. support@refx.gg
NEXT_PUBLIC_PRIVACY_EMAIL=               # e.g. privacy@refx.gg
NEXT_PUBLIC_LEGAL_EMAIL=                 # e.g. legal@refx.gg (abuse/legal)
NEXT_PUBLIC_LEGAL_JURISDICTION=          # e.g. the State of Delaware, USA
NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE=        # e.g. 1 July 2026
NEXT_PUBLIC_REFUND_WINDOW=               # e.g. 72 hours / 14 days
NEXT_PUBLIC_INFRA_PROVIDER=              # sub-processor: e.g. OVHcloud
NEXT_PUBLIC_EMAIL_PROVIDER=              # sub-processor: e.g. Postmark

# ---- Reverse proxy ----------------------------------------------------------
# Bind published container ports to loopback only; a Caddy/nginx proxy on the
# host fronts web (:3000) and api (:4000) over TLS. See infra/reverse-proxy/.
BIND_HOST=127.0.0.1
# Reverse-proxy hops to trust for X-Forwarded-For (one local proxy = 1).
TRUST_PROXY=1
# If you sit behind Cloudflare, set this so the real client IP is read from the
# trusted header (lock the firewall to Cloudflare IPs first). Else leave blank.
CLIENT_IP_HEADER=

# ---- Secrets (REQUIRED — generate strong random values) ---------------------
# AES-256-GCM master key for secrets at rest (gateway keys, TOTP seeds, SFTP/DB
# passwords). EXACTLY 64 hex chars. openssl rand -hex 32
# !! Once real encrypted data exists, NEVER change this — it is unrecoverable. !!
SECRETS_ENC_KEY=
# JWT signing — three DISTINCT random values. openssl rand -hex 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_MFA_SECRET=
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000
JWT_MFA_TTL=300

# ---- Database (PostgreSQL) — REQUIRED strong password -----------------------
POSTGRES_USER=refx
POSTGRES_PASSWORD=
POSTGRES_DB=refx
# Host is the compose service name `postgres` (not localhost). Keep the password
# in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://refx:CHANGE_ME@postgres:5432/refx?schema=public

# ---- Cache / queues (Redis) -------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Set a password and require it on the redis server if it is reachable beyond
# the compose network.
REDIS_PASSWORD=
REDIS_DB=0

# ---- Object storage (S3 / MinIO) — backups & attachments -------------------
# Point at real S3 or a hardened MinIO. Used for game-server backups AND the
# panel DB backup script (infra/scripts/backup-panel-db.sh).
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=refx-backups
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# ---- Panel DB backups (used by infra/scripts/backup-panel-db.sh) -----------
# Bucket/prefix for encrypted pg_dump artefacts and how many to keep.
PANEL_BACKUP_BUCKET=refx-db-backups
PANEL_BACKUP_PREFIX=panel-postgres
PANEL_BACKUP_RETENTION=14
# Passphrase to encrypt dumps at rest (openssl rand -hex 32). KEEP IT SAFE and
# OFF this host — without it a backup cannot be restored.
PANEL_BACKUP_PASSPHRASE=

# ---- Email (SMTP) — REQUIRED for password reset / verification / receipts ---
# Use a real transactional provider (Postmark/SES/Resend/Mailgun) on a domain
# with SPF + DKIM + DMARC. Without SMTP_HOST, emails are only logged.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ReFx Hosting <no-reply@refx.gg>"

# ---- Billing / payment gateways ---------------------------------------------
DEFAULT_CURRENCY=USD
INVOICE_NUMBER_PREFIX=INV
# Prefer setting keys in Owner → Payments (encrypted at rest); env is a fallback.
# Stripe: use LIVE keys (sk_live_…) + the webhook signing secret for
#   POST /api/v1/billing/webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STATEMENT_DESCRIPTOR=
# PayPal: live REST app; register the webhook + enable the recurring events.
PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ---- Node agent <-> panel ---------------------------------------------------
AGENT_REQUEST_TIMEOUT_MS=15000
# Pin each node's agent TLS cert after registration (Admin → Nodes → Pin), then
# turn this on so the panel rejects unknown certs.
AGENT_TLS_PINNING=true
# Read-only GitHub token if the repo/releases are private (for "Update agent").
GITHUB_TOKEN=

# ---- Mobile push (APNs) — optional; leave blank to disable cleanly ----------
# Keep the .p8 ONLY here/in secrets, NEVER in the repo. Prefer the base64 form.
APNS_KEY_P8_BASE64=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRODUCTION=true

# ---- Support / helpdesk -----------------------------------------------------
# Auto-progress stale tickets. SUPPORT_AUTORESOLVE=false disables both stages.
# A ticket awaiting the customer for N days auto-resolves; a resolved ticket idle
# M more days auto-closes (locks replies). Set a stage's days to 0 to skip it.
SUPPORT_AUTORESOLVE=true
SUPPORT_AUTORESOLVE_DAYS=7
SUPPORT_AUTOCLOSE_DAYS=3

# ---- Rate limiting ----------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ---- Observability ----------------------------------------------------------
GRAFANA_ADMIN_USER=admin
# Set a strong Grafana admin password.
GRAFANA_ADMIN_PASSWORD=
# Alertmanager UI port (alerts fire from infra/docker/prometheus/rules/).
ALERTMANAGER_PORT=9093

# ---- Seed -------------------------------------------------------------------
# Set a strong first-owner password, then change it on first sign-in.
SEED_OWNER_PASSWORD=
# Do NOT seed demo content into a production catalog.
SEED_DEMO=false

# ---- Emergency override (leave UNSET in normal operation) -------------------
# Set to true ONLY to bypass the boot-time preflight when you knowingly accept
# insecure config (e.g. emergency access). Unset it again immediately after.
# ALLOW_INSECURE_CONFIG=false
