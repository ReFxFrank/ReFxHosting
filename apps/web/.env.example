# ReFx Hosting — web panel environment
# Base URL of the panel-api (REST under /api/v1, WS for console).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: explicit WebSocket base. Defaults to NEXT_PUBLIC_API_URL with ws(s) scheme.
NEXT_PUBLIC_WS_URL=

# Public site URL (used for absolute links, OG metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Branding
NEXT_PUBLIC_BRAND_NAME=ReFx Hosting
# Bare domain shown on the legal/policy pages (no scheme).
NEXT_PUBLIC_SITE_DOMAIN=refx.gg
# iOS app link for the App Store badge (App Store or TestFlight URL). The app is
# live, so the code defaults to the published listing; set this only to override
# (e.g. a region-specific or TestFlight URL).
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/refx-server-manager/id6783853821
